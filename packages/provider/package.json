{
  "name": "@openmerch/provider",
  "version": "0.2.5",
  "description": "OpenMerch Provider SDK — register services, handle sync/async/streaming executions",
  "license": "MIT",
  "author": "OpenMerch",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmerch/openmerch-sdk.git",
    "directory": "packages/provider"
  },
  "homepage": "https://github.com/openmerch/openmerch-sdk/tree/main/packages/provider#readme",
  "bugs": {
    "url": "https://github.com/openmerch/openmerch-sdk/issues"
  },
  "keywords": [
    "openmerch",
    "mpp",
    "machine-payable",
    "ai-services",
    "provider",
    "sdk"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
